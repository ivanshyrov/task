{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/tasks/index.js"
    }
  ]
}

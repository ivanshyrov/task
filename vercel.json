{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/users",
      "dest": "/api/users/index.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}

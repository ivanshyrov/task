  "rewrites": [
    {
      "source": "/api/users",
      "destination": "/api/users/index.js"
    },
    {
      "source": "/api/users/(.*)",
      "destination": "/api/users/index.js"
    },
    {
      "source": "/api/tasks",
      "destination": "/api/tasks/index.js"
    },
    {
      "source": "/api/tasks/(.*)",
      "destination": "/api/tasks/index.js"
    }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "outputDirectory": "."
}

{"outputDirectory": ".", "headers": {"/api/(.*)": [{"key": "Access-Control-Allow-Origin", "value": "*"}, {"key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS"}, {"key": "Access-Control-Allow-Headers", "value": "Content-Type"}], "*.js": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}], "*.css": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}], "/index.html": [{"key": "Cache-Control", "value": "public, max-age=3600, must-revalidate"}]}, "rewrites": [{"source": "/(.*)", "destination": "/index.html"}]}
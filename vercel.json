{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    {
      "src": "/api/tasks/(.*)",
      "dest": "/api/tasks/index.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/tasks/index.js"
    }
  ],
  "env": {
    "SEATABLE_SERVER": "@seatable_server",
    "SEATABLE_API_TOKEN": "@seatable_api_token",
    "SEATABLE_BASE_UUID": "@seatable_base_uuid",
    "SEATABLE_USERS_TABLE": "Users"
  }
}
